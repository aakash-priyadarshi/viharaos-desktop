{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ViharaOS",
  "version": "0.1.4",
  "identifier": "com.viharaos.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm --filter @viharaos/web dev",
    "beforeBuildCommand": "pnpm --filter @viharaos/web build:static"
  },
  "app": {
    "windows": [
      {
        "title": "ViharaOS — Hotel Management System",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "alwaysOnTop": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' tauri://localhost asset: https://asset.localhost data: https://viharaos-image-proxy.aakashm301.workers.dev https://images.unsplash.com; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' http://localhost:* http://127.0.0.1:* https://api.viharaos.com https://api.viharaos.dev https://*.viharaos.dev https://github.com https://releases.githubusercontent.com https://*.githubusercontent.com; font-src 'self' data:"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2026 ViharaOS",
    "category": "Business",
    "publisher": "ViharaOS",
    "shortDescription": "Offline-first Hotel Management System",
    "longDescription": "ViharaOS is an offline-first Property Management System for hotels on the Indian Buddhist Circuit. The desktop app provides full offline capability with cloud sync when online.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "installMode": "perMachine",
        "languages": [
          "English"
        ],
        "displayLanguageSelector": false
      },
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.comodoca.com"
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": null,
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 480,
          "y": 200
        },
        "applicationFolderPosition": {
          "x": 180,
          "y": 200
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZDQzM5RTkzNzZEQjMyRUMKUldUc010dDJrNTdEYkZ1UGZzN1h3RDRpVFFvbkR6T0I1SjhCNDA4WnhvRDNtQ0s0WlA2b2xGZzcK",
      "endpoints": [
        "https://github.com/aakash-priyadarshi/viharaos-desktop/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
